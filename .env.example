# ===== Wazzup24 =====
# Секрет в URL вебхука: /webhook/wazzup/<secret>. У Wazzup нет подписи —
# защищаемся секретным путём. Обязателен: без него приложение не стартует.
# Сгенерируй длинный случайный:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# ВНИМАНИЕ: секрет попадает в access-log uvicorn (он в URL) — на проде
# запускать с --no-access-log (см. systemd-юнит, блок 12).
WAZZUP_WEBHOOK_SECRET=change-me-to-a-long-random-string
# Отправка сообщений (блок 7)
# WAZZUP_TOKEN=
# WAZZUP_CHANNEL_ID=00a456e4-973f-457b-8dad-2864ca224c5d

# ===== Supabase (блок 2) =====
# SUPABASE_URL=https://xbcynfwbsyufxaqtoror.supabase.co
# DSN для asyncpg: взять из Supabase → Connect → Session pooler (порт 5432, IPv4).
# Строка уже содержит sslmode=require — НЕ убирать. Прямой хост db.xxx (IPv6-only) не годится.
# SUPABASE_DB_DSN=postgresql://postgres.xbcynfwbsyufxaqtoror:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_SERVICE_KEY=                                          # для Storage (загрузка фото)
# SUPABASE_STORAGE_BUCKET=lead-photos

# ===== OpenAI (блоки 6/9/10) =====
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4.1
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== Telegram (блоки 8/11) =====
# Бот менеджера/алертов ("ассистент идей") — карточки лидов, takeover, block, эскалации
# TELEGRAM_MANAGER_BOT_TOKEN=
# TELEGRAM_MANAGER_CHAT_ID=1009982311
# Отдельный бот для лид-алертов (если решим разнести приём и алерты по двум ботам)
# TELEGRAM_ALERT_BOT_TOKEN=
# --- Менеджер-бот (блок 11): приём команд/кнопок ---
# Секрет в пути Telegram-вебхука: <домен>/webhook/telegram/<secret>. Пусто → эндпоинт 403.
# TG_WEBHOOK_SECRET=
# Кто управляет ботом (Telegram user_id через запятую). Пусто → фолбэк на chat_id Ани/разработки.
# TG_MANAGER_ADMIN_IDS=1009982311
# Контакт для запроса доступа (показывается чужим). Telegram-хендл с @.
# SUPPORT_CONTACT=@arinashrr

# Номера-исключения silent-фильтра (тестовые/доверенные, цифры через запятую)
# SILENT_BYPASS_PHONES=79991112233,79994445566
